# Client (browser) — must be prefixed with VITE_
VITE_APP_URL=http://localhost:3046

# PostHog product analytics (optional — omit locally to disable)

# Server runtime (local dev + Vercel env vars)
ADMIN_EMAIL=you@example.com
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3046
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3046

# Legacy fallback while migrating local env files:
# ADMIN_SESSION_SECRET=

# Runtime DB is Cloudflare D1 (`env.DB` via cloudflare:workers / wrangler).
# Shared DB name with portfolio: `tigawanna`
# Apply migrations: pnpm db:migrate:local | pnpm db:migrate:remote

# Turso — import / migration scripts only (not used by getDb at runtime)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=

# Contact form -> Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + recently pushed repos)
GH_PAT=

# Project enrichment (OpenRouter)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Dev.to articles API
DEV_TO_KEY=

