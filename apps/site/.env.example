# Client (browser) — must be prefixed with VITE_
VITE_APP_URL=http://localhost:3044

# PostHog product analytics (optional — omit locally to disable)
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Server runtime (local dev + Vercel env vars)
ADMIN_EMAIL=you@example.com
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3044
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3044

# Legacy fallback while migrating local env files:
# ADMIN_SESSION_SECRET=

# Local SQLite (default). Omit to use file:./local.db in apps/site/
# DATABASE_URL=file:./local.db

# Turso (production)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=

# Contact form -> Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + recently pushed repos)
GH_PAT=

# Project enrichment (OpenRouter)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Dev.to articles API
DEV_TO_KEY=

# PostHog server-side capture (same project token as VITE_POSTHOG_KEY)
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com
