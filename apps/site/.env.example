# Client (browser) — must be prefixed with VITE_
VITE_APP_URL=http://localhost:3044

# Server runtime (local dev + Vercel env vars)
ADMIN_EMAIL=you@example.com
ADMIN_SESSION_SECRET=

# Local SQLite (default). Omit to use file:./local.db in apps/site/
# DATABASE_URL=file:./local.db

# Turso (production)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=

# Contact form + backstage OTP -> Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + recently pushed repos)
GH_PAT=

# Dev.to articles API
DEV_TO_KEY=

# PocketBase URL for TIL / journal snippets (portfolio_milestones collection)
PB_URL=

# Optional: skip backstage auth guards in local dev
# BYPASS_AUTH=true
