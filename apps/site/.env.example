# Client (browser) — must be prefixed with VITE_
VITE_APP_URL=http://localhost:3044

# Worker runtime — copy to .dev.vars for local dev
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3044
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAIL=

# Contact form -> Telegram notification + D1 archive
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + currently-working-on repos)
GH_PAT=

# Dev.to articles API
DEV_TO_KEY=

# PocketBase URL for TIL / journal snippets (portfolio_milestones collection)
PB_URL=

# Optional: skip backstage auth guards in local dev
# BYPASS_AUTH=true
