# Client (browser) — must be prefixed with VITE_
VITE_API_URL=http://localhost:3044

# Public site URL used by Better Auth / metadata
FRONTEND_URL=http://localhost:3044

# Contact form -> Telegram notification
# Create a bot via @BotFather to get the token, and use @userinfobot / getUpdates for the chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + currently-working-on repos)
# Fine-grained or classic PAT with public repo + read access
GH_PAT=

# Dev.to articles API
DEV_TO_KEY=

# PocketBase URL for TIL / journal snippets (portfolio_milestones collection)
PB_URL=

# Turso / libSQL database (projects, journal, embeddings)
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=

# Better Auth (admin login)
BETTER_AUTH_SECRET=
REFRESH_TOKEN_SECRET=

# Local dev logging
LOG_DEBUG=true
