# Client (browser) — must be prefixed with VITE_
VITE_APP_URL=http://localhost:3045

# PostHog product analytics (optional — omit locally to disable)
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Runtime DB is Cloudflare D1 (`env.DB` via cloudflare:workers / wrangler).
# Shared DB name with dashboard: `tigawanna`
# Apply migrations: pnpm db:migrate:local | pnpm db:migrate:remote

# Turso — import / migration scripts only (not used by getDb at runtime)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=

# Contact form -> Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# GitHub GraphQL (pinned + recently pushed repos)
GH_PAT=

# Dev.to articles API
DEV_TO_KEY=

# PostHog server-side capture (same project token as VITE_POSTHOG_KEY)
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com
