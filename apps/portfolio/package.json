{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3045",
    "build": "echo \"[skip] portfolio Cloudflare migration — build skipped\" && exit 0",
    "preview": "vp preview",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:cf": "pnpm run build && wrangler deploy",
    "deploy:vercel": "vercel --prod",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vp test run",
    "test:e2e": "playwright test --config e2e/landing/playwright.config.ts",
    "test:e2e:gg": "LANDING_PATH=/gg playwright test --config e2e/landing/playwright.config.ts",
    "test:e2e:install": "playwright install chromium",
    "check-types": "echo \"[skip] portfolio Cloudflare migration — check-types skipped\" && exit 0",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:studio:d1": "DATABASE_URL=\"file:$(find .wrangler/state/v3/d1 -name '*.sqlite' ! -name metadata.sqlite 2>/dev/null | head -1)\" drizzle-kit studio --config drizzle.config.ts --port ${DRIZZLE_STUDIO_D1_PORT:-4984}",
    "db:studio": "pnpm run db:studio:d1",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:migrate:local": "wrangler d1 migrations apply tigawanna --local",
    "db:migrate:remote": "wrangler d1 migrations apply tigawanna --remote",
    "build:cf": "vp build",
    "check-types:cf": "tsc -b --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@posthog/react": "^1.10.3",
    "@repo/db": "workspace:*",
    "@repo/github": "workspace:*",
    "@repo/telegram": "workspace:*",
    "@repo/ui": "workspace:*",
    "@shikijs/langs": "^3.23.0",
    "@shikijs/themes": "^3.23.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanem/react-nprogress": "^6.0.3",
    "@tanstack/db": "^0.6.10",
    "@tanstack/query-db-collection": "^1.0.42",
    "@tanstack/react-db": "^0.1.88",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "@uiw/react-md-editor": "^4.1.1",
    "animejs": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "daisyui": "^5.5.23",
