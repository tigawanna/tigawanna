    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@latest",
    "posthog-node": "^5.42.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-hotkeys-hook": "^5.3.2",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.11.2",
